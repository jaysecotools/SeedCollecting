        // Scenario functions (keep your original implementation)
        function selectScenarioOption(element, scenarioNum, choice) {
            const options = document.querySelectorAll(`#scenario${scenarioNum}-options .scenario-option`);
            options.forEach(opt => opt.classList.remove('selected'));
            
            element.classList.add('selected');
            
            const feedback = {
                1: {
                    'A': '❌ **Not ideal.** Collecting 50% from a small population (only 12 plants) risks the long-term survival of this isolated stand. The 20% rule exists for good reason.',
                    'B': '❌ **Too drastic.** Abandoning completely wastes the trip and doesn\'t contribute to collection targets. Better to collect sustainably.',
                    'C': '✅ **Good practice.** Collecting from half the plants at 10% is a cautious, sustainable approach that protects the population while still getting seed.',
                    'D': '🟡 **Acceptable but monitor.** Collecting less than 20% from all plants is better than option A, but in a population this small, fewer plants (5-6) with lighter take is even safer.'
                },
                2: {
                    'A': '❌ **Unsafe decision.** Strong winds and rain increase risks of falls, hypothermia, and difficult navigation. Safety first – always.',
                    'B': '✅ **Correct decision.** Packing up early and heading back ensures the team\'s safety. Seed collection can be rescheduled; injuries cannot.',
                    'C': '❌ **Risky.** Sheltering might delay the inevitable, and conditions can deteriorate faster than expected. Best to leave early.',
                    'D': '🟡 **Slows response.** Radioing base is good, but you already have the key info (weather coming). Trust your judgment and head back.'
                },
                3: {
                    'A': '❌ **Never collect if uncertain.** Collecting the wrong species could spread seed of a non-target or even weedy species, and wastes collection effort.',
                    'B': '✅ **Best practice.** Pressing a voucher allows later positive ID. Never collect seed from an uncertain species – wait for confirmation.',
                    'C': '🟡 **Better, but still risky.** Collecting seed before positive ID could still lead to misidentification. Voucher first, collect later if confirmed.',
                    'D': '❌ **Not sufficient.** Photos help, but without a pressed specimen or expert confirmation, you cannot be certain. Do not collect.'
                }
            };
            
            const feedbackDiv = document.getElementById(`scenario${scenarioNum}-feedback`);
            const feedbackText = document.getElementById(`scenario${scenarioNum}-text`);
            
            feedbackText.innerHTML = feedback[scenarioNum][choice];
            feedbackDiv.style.display = 'block';
            
            if (choice === 'A' || (scenarioNum === 1 && choice === 'A') || (scenarioNum === 2 && choice === 'A') || (scenarioNum === 3 && choice === 'A')) {
                feedbackDiv.className = 'scenario-feedback feedback-poor';
            } else if (choice === 'B' && scenarioNum !== 1) {
                feedbackDiv.className = 'scenario-feedback feedback-good';
            } else if ((scenarioNum === 1 && choice === 'C') || (scenarioNum === 1 && choice === 'D')) {
                feedbackDiv.className = choice === 'C' ? 'scenario-feedback feedback-good' : 'scenario-feedback feedback-risky';
            } else if (choice === 'B' || choice === 'C') {
                feedbackDiv.className = 'scenario-feedback feedback-risky';
            } else {
                feedbackDiv.className = 'scenario-feedback feedback-poor';
            }
        }

        function resetScenario(scenarioNum) {
            const options = document.querySelectorAll(`#scenario${scenarioNum}-options .scenario-option`);
            options.forEach(opt => opt.classList.remove('selected'));
            
            document.getElementById(`scenario${scenarioNum}-feedback`).style.display = 'none';
        }

