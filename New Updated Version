<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title>AHCECR305 · Collect Native Seed · Complete Learning Ecosystem</title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary-dark: #0f3b2c;
            --primary-medium: #1d5e45;
            --primary-light: #4a8b6e;
            --accent-gold: #f5b342;
            --accent-soft: #fff2db;
            --bg-light: #f3faf3;
            --text-dark: #1a3326;
            --border-light: #c5e0c5;
            --card-shadow: 0 20px 40px -10px rgba(0, 40, 0, 0.2);
            --footer-text: #f0ffe0;
            --footer-heading: #ffda7a;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Roboto, system-ui, sans-serif;
            background: #d9ead9;
            color: var(--text-dark);
            line-height: 1.7;
            padding: 1rem;
        }

        .master-ecosystem {
            max-width: 1800px;
            margin: 0 auto;
            background: white;
            border-radius: 3rem;
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        /* ===== HERO SECTION ===== */
        .hero-banner {
            background: linear-gradient(165deg, #0a3625, #1b6b4c, #144d36);
            color: white;
            padding: 2.5rem 2rem;
            border-bottom: 12px solid var(--accent-gold);
            position: relative;
        }

        .hero-banner h1 {
            font-size: clamp(2.2rem, 8vw, 4.2rem);
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1.2;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.2);
            word-break: break-word;
        }

        .hero-banner h1 i {
            color: var(--accent-gold);
            margin-right: 10px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));
        }

        .hero-qual {
            display: flex;
            gap: 1rem;
            margin-top: 1.5rem;
            font-size: 0.95rem;
            flex-wrap: wrap;
        }

        .hero-qual span {
            background: rgba(255,255,240,0.15);
            backdrop-filter: blur(5px);
            padding: 0.6rem 1.2rem;
            border-radius: 60px;
            border-left: 5px solid var(--accent-gold);
            font-weight: 500;
        }

        /* ===== TABBED NAVIGATION (with ARIA roles) ===== */
        .tab-bar {
            background: #154f34;
            padding: 0.5rem 1rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.25rem;
            border-bottom: 3px solid #a8d0a8;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 8px 20px rgba(0,20,0,0.2);
        }

        .tab {
            color: #e0f0da;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 0.8rem 1rem;
            cursor: pointer;
            border-bottom: 4px solid transparent;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
            background: transparent;
            border: none;
            font-family: inherit;
            border-radius: 8px 8px 0 0;
            flex: 0 1 auto;
        }

        .tab:hover {
            background: #216344;
            color: white;
        }

        .tab.active {
            color: white;
            border-bottom-color: var(--accent-gold);
            background: linear-gradient(transparent 60%, rgba(245,179,66,0.15) 100%);
        }

        .tab i {
            font-size: 1rem;
        }

        /* ===== MAIN TAB CONTENT AREA ===== */
        .tab-content {
            display: none;
            padding: 2rem 1.5rem;
            background: white;
            animation: fadeIn 0.5s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0.3; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== CONTENT STYLING (mobile optimised) ===== */
        h2 {
            font-size: clamp(1.8rem, 5vw, 2.8rem);
            font-weight: 700;
            color: var(--primary-dark);
            margin: 1.5rem 0 1.5rem 0;
            border-left: 15px solid var(--accent-gold);
            padding-left: 1.2rem;
            letter-spacing: -0.01em;
            line-height: 1.2;
        }

        h2:first-of-type {
            margin-top: 0;
        }

        h3 {
            font-size: clamp(1.4rem, 4vw, 2rem);
            font-weight: 650;
            color: #1b5a3a;
            margin: 2rem 0 1rem 0;
            border-bottom: 4px dashed #bfe0bf;
            padding-bottom: 0.7rem;
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        h4 {
            font-size: clamp(1.2rem, 3.5vw, 1.6rem);
            color: #154f31;
            margin: 1.5rem 0 1rem;
            font-weight: 650;
        }

        h5 {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0f462f;
            margin: 1.2rem 0 0.8rem;
        }

        .card-deck {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .info-card {
            background: var(--bg-light);
            border-radius: 1.5rem;
            padding: 1.5rem;
            border: 1px solid var(--border-light);
            box-shadow: 0 10px 25px rgba(0,30,0,0.08);
            transition: transform 0.2s;
        }

        .info-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 30px rgba(0,60,0,0.15);
        }

        .info-card i {
            font-size: 2rem;
            color: var(--primary-medium);
            margin-bottom: 1rem;
        }

        .legislation-panel {
            background: #eef5ee;
            border-radius: 1.5rem;
            padding: 1.5rem;
            margin: 2rem 0;
            border-left: 12px solid #2a6e5a;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.02);
        }

        .act-list {
            columns: 1;
            column-gap: 2rem;
            margin: 1.5rem 0;
        }
        
        @media (min-width: 768px) {
            .act-list {
                columns: 2;
            }
        }

        .act-item {
            break-inside: avoid;
            padding: 0.8rem;
            background: white;
            border-radius: 60px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        }

        .act-item i {
            color: var(--accent-gold);
            font-size: 1.2rem;
            width: 2rem;
            text-align: center;
        }

        .fruit-type-showcase {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
            margin: 2rem 0;
        }

        .fruit-pillar {
            flex: 1 1 250px;
            background: #f9fff9;
            border-radius: 1.5rem;
            padding: 1.5rem;
            text-align: center;
            box-shadow: 0 10px 20px rgba(0,20,0,0.1);
            border: 2px solid transparent;
        }

        .fruit-pillar.A { border-top: 12px solid #c45d9b; }
        .fruit-pillar.B { border-top: 12px solid #d4a13e; }
        .fruit-pillar.C { border-top: 12px solid #7f9a6b; }

        .fruit-pillar h5 { font-size: 1.5rem; margin-top: 0.5rem; }
        .fruit-pillar ul { text-align: left; margin-top: 1.5rem; }

        /* ===== QUIZ STYLES ===== */
        .quiz-container {
            background: #1e3d2e;
            color: #fff8e7;
            border-radius: 2rem;
            padding: 1.5rem;
            margin: 2.5rem 0;
        }

        .quiz-question-card {
            background: #2d543a;
            border-radius: 1.5rem;
            padding: 1.5rem;
            margin: 1.5rem 0;
        }

        .quiz-question {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 1.2rem;
        }

        .quiz-option {
            background: #3f6a4a;
            margin: 0.8rem 0;
            padding: 0.8rem 1.5rem;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.1s;
            border: 2px solid transparent;
        }

        .quiz-option:hover {
            background: #568b5e;
            transform: scale(1.01);
        }

        .quiz-option input {
            margin-right: 1rem;
            transform: scale(1.2);
            accent-color: var(--accent-gold);
        }

        .quiz-feedback {
            display: none;
            margin-top: 1.2rem;
            padding: 1.2rem;
            border-radius: 1rem;
            font-weight: 500;
        }

        .feedback-correct { background: #2f7d4f; }
        .feedback-incorrect { background: #a14f4f; }

        .btn {
            background: var(--accent-gold);
            color: #1a401a;
            border: none;
            font-weight: 700;
            padding: 0.8rem 1.8rem;
            border-radius: 60px;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.2s;
            border: 2px solid transparent;
            margin: 0.5rem 0.5rem 0.5rem 0;
            display: inline-block;
        }

        .btn:hover {
            background: #ffc55a;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .btn-outline {
            background: transparent;
            border: 3px solid var(--primary-medium);
            color: var(--primary-medium);
        }
        
        .btn-outline:hover {
            background: var(--primary-medium);
            color: white;
        }

        /* ===== CHECKLIST STYLES ===== */
        .checklist-super {
            background: white;
            border: 4px solid var(--primary-medium);
            border-radius: 2rem;
            padding: 1.5rem;
            margin: 2rem 0;
            box-shadow: var(--card-shadow);
        }

        .checklist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 1rem;
            margin: 1.5rem 0;
        }

        .checklist-item {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            padding: 0.6rem 1rem;
            background: #f0faf0;
            border-radius: 60px;
        }

        .checklist-item input[type="checkbox"] {
            width: 22px;
            height: 22px;
            flex-shrink: 0;
            accent-color: var(--primary-medium);
        }

        /* ===== DRAG & DROP GAME STYLES ===== */
        .game-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin: 2rem 0;
        }
        
        @media (min-width: 900px) {
            .game-container {
                grid-template-columns: 1fr 1fr;
            }
        }
        
        .drag-area {
            background: #fff2db;
            border-radius: 1.5rem;
            padding: 1.5rem;
            min-height: 300px;
        }
        
        .drop-area {
            background: #e3f1e3;
            border-radius: 1.5rem;
            padding: 1.5rem;
            min-height: 300px;
        }
        
        .drop-zone {
            background: rgba(196,93,155,0.1);
            border: 3px dashed #c45d9b;
            border-radius: 1.5rem;
            padding: 1rem;
            margin: 1rem 0;
            min-height: 70px;
            transition: all 0.2s;
        }
        
        .drop-zone.B { border-color: #d4a13e; }
        .drop-zone.C { border-color: #7f9a6b; }
        
        .draggable-item {
            background: white;
            border-radius: 60px;
            padding: 0.7rem 1.2rem;
            margin: 0.5rem 0;
            cursor: grab;
            display: inline-block;
            border: 2px solid var(--primary-medium);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            transition: all 0.1s;
        }
        
        .draggable-item:active {
            cursor: grabbing;
            opacity: 0.8;
        }
        
        .dropped-item {
            background: #154f34;
            color: white;
            border-radius: 60px;
            padding: 0.5rem 1rem;
            margin: 0.3rem;
            display: inline-block;
            font-size: 0.9rem;
            border: 2px solid white;
        }

        /* ===== TOOL TABLE ===== */
        .tool-matrix {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 1.5rem;
            overflow: hidden;
            box-shadow: 0 15px 30px rgba(0,20,0,0.1);
            margin: 2rem 0;
            display: block;
            overflow-x: auto;
            white-space: nowrap;
        }
        
        @media (min-width: 768px) {
            .tool-matrix {
                display: table;
                white-space: normal;
            }
        }

        .tool-matrix th {
            background: var(--primary-medium);
            color: white;
            padding: 1rem;
            font-size: 1rem;
        }

        .tool-matrix td {
            padding: 1rem;
            border-bottom: 1px solid #c5e0c5;
            vertical-align: top;
        }

        .tool-matrix tr:last-child td {
            border-bottom: none;
        }

        /* ===== RISK MATRIX ===== */
        .risk-table {
            width: 100%;
            border-collapse: collapse;
            display: block;
            overflow-x: auto;
        }

        .risk-table th {
            background: #154f34;
            color: white;
            padding: 0.8rem;
        }

        .risk-table td {
            border: 2px solid #b5d6b5;
            padding: 0.8rem;
            text-align: center;
            font-weight: 600;
        }

        .risk-low { background: #c8e6c8; }
        .risk-medium { background: #fff3b0; }
        .risk-high { background: #ffb5b5; }
        .risk-extreme { background: #ff8080; color: white; }

        /* ===== GLOSSARY STYLES ===== */
        .glossary-term {
            display: inline-block;
            background: #e3f1e3;
            border-bottom: 2px dotted var(--primary-medium);
            cursor: help;
            position: relative;
            font-weight: 500;
            padding: 0 4px;
            margin: 0 2px;
        }

        .glossary-definition {
            display: none;
            position: absolute;
            background: var(--primary-dark);
            color: white;
            padding: 0.8rem 1.2rem;
            border-radius: 1rem;
            width: min(250px, 80vw);
            left: 50%;
            transform: translateX(-50%);
            bottom: 100%;
            margin-bottom: 10px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            z-index: 1000;
            font-size: 0.85rem;
            font-weight: normal;
            border: 3px solid var(--accent-gold);
        }

        .glossary-term:hover .glossary-definition {
            display: block;
        }

        .glossary-definition::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -8px;
            border-width: 8px;
            border-style: solid;
            border-color: var(--primary-dark) transparent transparent transparent;
        }

        /* ===== PHOTO GALLERY STYLES ===== */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .gallery-item {
            background: var(--bg-light);
            border-radius: 1.5rem;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,20,0,0.1);
            transition: transform 0.3s;
            border: 2px solid var(--border-light);
        }

        .gallery-item:hover {
            transform: scale(1.02);
        }

        .gallery-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-bottom: 4px solid var(--accent-gold);
            background: #d9ead9;
        }

        .gallery-caption {
            padding: 1rem;
        }

        .gallery-caption h4 {
            margin: 0 0 0.3rem 0;
            color: var(--primary-dark);
            font-size: 1.2rem;
        }

        .gallery-caption p {
            margin: 0;
            font-size: 0.9rem;
            color: #2a4a2a;
        }

        .photo-credit {
            font-size: 0.75rem;
            color: #666;
            margin-top: 0.5rem;
            font-style: italic;
        }

        /* ===== SCENARIO STYLES ===== */
        .scenario-box {
            background: #fff2db;
            border-radius: 1.5rem;
            padding: 1.5rem;
            margin: 2rem 0;
            border-left: 12px solid var(--accent-gold);
            box-shadow: var(--card-shadow);
        }

        .scenario-question {
            background: white;
            border-radius: 1.2rem;
            padding: 1.2rem;
            margin: 1.2rem 0;
            border: 2px solid var(--primary-light);
        }

        .scenario-options {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            margin: 1.2rem 0;
        }

        .scenario-option {
            background: white;
            border: 2px solid var(--border-light);
            border-radius: 60px;
            padding: 0.8rem 1.2rem;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.95rem;
        }

        .scenario-option:hover {
            background: var(--accent-soft);
            border-color: var(--accent-gold);
        }

        .scenario-option.selected {
            background: var(--primary-medium);
            color: white;
            border-color: var(--accent-gold);
        }

        .scenario-feedback {
            display: none;
            background: white;
            border-radius: 1.2rem;
            padding: 1.2rem;
            margin-top: 1.2rem;
            border: 4px solid;
        }

        .feedback-good {
            border-color: #2f7d4f;
        }

        .feedback-risky {
            border-color: var(--accent-gold);
        }

        .feedback-poor {
            border-color: #a14f4f;
        }

        /* ===== RESOURCES TAB ===== */
        .resources-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .resource-card {
            background: var(--bg-light);
            border-radius: 2rem;
            padding: 2rem 1.5rem;
            border: 2px solid var(--border-light);
            transition: transform 0.2s;
            height: 100%;
        }

        .resource-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,60,0,0.15);
        }

        .resource-card h3 {
            margin-top: 0;
            border-bottom: none;
            color: var(--primary-dark);
            font-size: 1.8rem;
            gap: 10px;
        }

        .resource-card ul {
            list-style: none;
            margin-top: 1.5rem;
        }

        .resource-card li {
            margin: 1rem 0;
            padding: 0.5rem 0;
            border-bottom: 1px dashed var(--border-light);
        }

        .resource-card a {
            color: var(--primary-medium);
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: color 0.2s;
        }

        .resource-card a:hover {
            color: var(--accent-gold);
            text-decoration: underline;
        }

        .resource-card i {
            font-size: 1.4rem;
            width: 2rem;
            color: var(--primary-dark);
        }

        /* ===== FOOTER ===== */
        .footer-expanded {
            background: #0f3829;
            color: var(--footer-text);
            padding: 2rem 1.5rem;
            margin-top: 2rem;
            border-top: 8px solid var(--accent-gold);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        
        @media (min-width: 640px) {
            .footer-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (min-width: 1024px) {
            .footer-grid {
                grid-template-columns: repeat(4, 1fr);
            }
        }
        
        .footer-expanded h4, .footer-expanded h5 {
            color: var(--footer-heading);
            font-weight: 700;
            margin-bottom: 1rem; 
            font-size: 1.2rem;
        }
        
        .footer-expanded a {
            color: var(--footer-heading);
            text-decoration: none;
            border-bottom: 1px dotted var(--footer-heading);
            word-break: break-word;
        }
        
        .footer-expanded a:hover {
            color: white;
            border-bottom: 1px solid white;
        }

        .footer-expanded ul {
            list-style: none;
        }

        .footer-expanded li {
            margin: 0.5rem 0;
        }

        /* ===== PRINT STYLES ===== */
        @media print {
            .tab-bar, .btn, .hero-banner, .quiz-container, .game-container, 
            .gallery-grid, .glossary-term, .scenario-box { 
                display: none !important; 
            }
            .tab-content { 
                display: block !important; 
                page-break-after: always;
                padding: 1rem;
            }
            body { 
                background: white; 
                padding: 0;
                font-size: 11pt;
            }
            .checklist-super {
                border: 2px solid black;
                box-shadow: none;
                page-break-inside: avoid;
            }
            .footer-expanded {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="master-ecosystem">
        <!-- HERO SECTION -->
        <div class="hero-banner">
            <h1><i class="fas fa-seedling"></i> AHCECR305 · Collect Native Seed</h1>
            <div class="hero-qual">
                <span><i class="fas fa-certificate"></i> Certificate III in Conservation & Ecosystem Management</span>
                <span><i class="fas fa-clipboard-check"></i> Release 1.4 · 2026</span>
                <span><i class="fas fa-flask"></i> Florabank · NRE Tas · Understorey Network</span>
            </div>
        </div>

        <!-- EXPANDED TABBED NAVIGATION with ARIA roles -->
        <div class="tab-bar" role="tablist" aria-label="Learning modules">
            <button class="tab active" id="tab-tab1" role="tab" aria-selected="true" aria-controls="tab1" onclick="switchTab(event, 'tab1')"><i class="fas fa-balance-scale"></i> <span>Legislation</span></button>
            <button class="tab" id="tab-tab2" role="tab" aria-selected="false" aria-controls="tab2" onclick="switchTab(event, 'tab2')"><i class="fas fa-map-signs"></i> <span>Planning</span></button>
            <button class="tab" id="tab-tab3" role="tab" aria-selected="false" aria-controls="tab3" onclick="switchTab(event, 'tab3')"><i class="fas fa-search"></i> <span>Species ID</span></button>
