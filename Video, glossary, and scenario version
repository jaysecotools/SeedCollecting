<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AHCECR305 · Collect Native Seed · Complete Learning Ecosystem</title>
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary-dark: #0f3b2c;
            --primary-medium: #1d5e45;
            --primary-light: #4a8b6e;
            --accent-gold: #f5b342;
            --accent-soft: #fff2db;
            --bg-light: #f3faf3;
            --text-dark: #1a3326;
            --border-light: #c5e0c5;
            --card-shadow: 0 20px 40px -10px rgba(0, 40, 0, 0.2);
            --footer-text: #f0ffe0;
            --footer-heading: #ffda7a;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Roboto, system-ui, sans-serif;
            background: #d9ead9;
            color: var(--text-dark);
            line-height: 1.7;
            padding: 1.5rem;
        }

        .master-ecosystem {
            max-width: 1800px;
            margin: 0 auto;
            background: white;
            border-radius: 3rem;
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }

        /* ===== HERO SECTION ===== */
        .hero-banner {
            background: linear-gradient(165deg, #0a3625, #1b6b4c, #144d36);
            color: white;
            padding: 3.5rem 4rem;
            border-bottom: 12px solid var(--accent-gold);
            position: relative;
        }

        .hero-banner h1 {
            font-size: 4.2rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1.2;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.2);
        }

        .hero-banner h1 i {
            color: var(--accent-gold);
            margin-right: 20px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));
        }

        .hero-qual {
            display: flex;
            gap: 2.5rem;
            margin-top: 2rem;
            font-size: 1.0rem;
            flex-wrap: wrap;
        }

        .hero-qual span {
            background: rgba(255,255,240,0.15);
            backdrop-filter: blur(5px);
            padding: 0.6rem 1.8rem;
            border-radius: 60px;
            border-left: 5px solid var(--accent-gold);
            font-weight: 500;
        }

        /* ===== TABBED NAVIGATION ===== */
        .tab-bar {
            background: #154f34;
            padding: 0 3rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            border-bottom: 3px solid #a8d0a8;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 8px 20px rgba(0,20,0,0.2);
        }

        .tab {
            color: #e0f0da;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 1.2rem 1.8rem;
            cursor: pointer;
            border-bottom: 4px solid transparent;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            border: none;
            font-family: inherit;
        }

        .tab:hover {
            background: #216344;
            color: white;
        }

        .tab.active {
            color: white;
            border-bottom-color: var(--accent-gold);
            background: linear-gradient(transparent 60%, rgba(245,179,66,0.15) 100%);
        }

        .tab i {
            font-size: 1.2rem;
        }

        /* ===== MAIN TAB CONTENT AREA ===== */
        .tab-content {
            display: none;
            padding: 3rem 3.5rem;
            background: white;
            animation: fadeIn 0.5s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0.3; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== CONTENT STYLING ===== */
        h2 {
            font-size: 2.8rem;
            font-weight: 700;
            color: var(--primary-dark);
            margin: 2rem 0 2rem 0;
            border-left: 20px solid var(--accent-gold);
            padding-left: 1.8rem;
            letter-spacing: -0.01em;
        }

        h2:first-of-type {
            margin-top: 0;
        }

        h3 {
            font-size: 2rem;
            font-weight: 650;
            color: #1b5a3a;
            margin: 2.5rem 0 1.5rem 0;
            border-bottom: 4px dashed #bfe0bf;
            padding-bottom: 0.7rem;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        h4 {
            font-size: 1.6rem;
            color: #154f31;
            margin: 2rem 0 1rem;
            font-weight: 650;
        }

        h5 {
            font-size: 1.3rem;
            font-weight: 600;
            color: #0f462f;
            margin: 1.5rem 0 0.8rem;
        }

        .card-deck {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            margin: 2.5rem 0;
        }

        .info-card {
            background: var(--bg-light);
            border-radius: 2rem;
            padding: 2rem;
            border: 1px solid var(--border-light);
            box-shadow: 0 10px 25px rgba(0,30,0,0.08);
            transition: transform 0.2s;
        }

        .info-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 30px rgba(0,60,0,0.15);
        }

        .info-card i {
            font-size: 2.5rem;
            color: var(--primary-medium);
            margin-bottom: 1rem;
        }

        .legislation-panel {
            background: #eef5ee;
            border-radius: 2rem;
            padding: 2.5rem;
            margin: 2rem 0;
            border-left: 12px solid #2a6e5a;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.02);
        }

        .act-list {
            columns: 2;
            column-gap: 3rem;
            margin: 1.5rem 0;
        }

        .act-item {
            break-inside: avoid;
            padding: 0.8rem;
            background: white;
            border-radius: 60px;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.05);
        }

        .act-item i {
            color: var(--accent-gold);
            font-size: 1.4rem;
            width: 2rem;
            text-align: center;
        }

        .fruit-type-showcase {
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
            margin: 2rem 0;
        }

        .fruit-pillar {
            flex: 1 1 250px;
            background: #f9fff9;
            border-radius: 2rem;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 10px 20px rgba(0,20,0,0.1);
            border: 2px solid transparent;
        }

        .fruit-pillar.A { border-top: 12px solid #c45d9b; }
        .fruit-pillar.B { border-top: 12px solid #d4a13e; }
        .fruit-pillar.C { border-top: 12px solid #7f9a6b; }

        .fruit-pillar h5 { font-size: 1.8rem; margin-top: 0.5rem; }
        .fruit-pillar ul { text-align: left; margin-top: 1.5rem; }

        /* ===== QUIZ STYLES ===== */
        .quiz-container {
            background: #1e3d2e;
            color: #fff8e7;
            border-radius: 2.5rem;
            padding: 2.5rem;
            margin: 3rem 0;
        }

        .quiz-question-card {
            background: #2d543a;
            border-radius: 1.8rem;
            padding: 2rem;
            margin: 2rem 0;
        }

        .quiz-question {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .quiz-option {
            background: #3f6a4a;
            margin: 0.8rem 0;
            padding: 1rem 2rem;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.1s;
            border: 2px solid transparent;
        }

        .quiz-option:hover {
            background: #568b5e;
            transform: scale(1.01);
        }

        .quiz-option input {
            margin-right: 1rem;
            transform: scale(1.2);
            accent-color: var(--accent-gold);
        }

        .quiz-feedback {
            display: none;
            margin-top: 1.5rem;
            padding: 1.5rem;
            border-radius: 1rem;
            font-weight: 500;
        }

        .feedback-correct { background: #2f7d4f; }
        .feedback-incorrect { background: #a14f4f; }

        .btn {
            background: var(--accent-gold);
            color: #1a401a;
            border: none;
            font-weight: 700;
            padding: 1rem 2.5rem;
            border-radius: 60px;
            font-size: 1.2rem;
            cursor: pointer;
            transition: 0.2s;
            border: 2px solid transparent;
            margin: 0.5rem;
        }

        .btn:hover {
            background: #ffc55a;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .btn-outline {
            background: transparent;
            border: 3px solid var(--primary-medium);
            color: var(--primary-medium);
        }
        
        .btn-outline:hover {
            background: var(--primary-medium);
            color: white;
        }

        /* ===== CHECKLIST STYLES ===== */
        .checklist-super {
            background: white;
            border: 4px solid var(--primary-medium);
            border-radius: 2.5rem;
            padding: 2.5rem;
            margin: 2.5rem 0;
            box-shadow: var(--card-shadow);
        }

        .checklist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.2rem;
            margin: 2rem 0;
        }

        .checklist-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.8rem 1.2rem;
            background: #f0faf0;
            border-radius: 60px;
        }

        .checklist-item input[type="checkbox"] {
            width: 24px;
            height: 24px;
            accent-color: var(--primary-medium);
        }

        /* ===== DRAG & DROP GAME STYLES ===== */
        .game-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin: 2rem 0;
        }
        
        .drag-area {
            background: #fff2db;
            border-radius: 2rem;
            padding: 2rem;
            min-height: 350px;
        }
        
        .drop-area {
            background: #e3f1e3;
            border-radius: 2rem;
            padding: 2rem;
            min-height: 350px;
        }
        
        .drop-zone {
            background: rgba(196,93,155,0.1);
            border: 3px dashed #c45d9b;
            border-radius: 2rem;
            padding: 1.5rem;
            margin: 1rem 0;
            min-height: 80px;
            transition: all 0.2s;
        }
        
        .drop-zone.B { border-color: #d4a13e; }
        .drop-zone.C { border-color: #7f9a6b; }
        
        .draggable-item {
            background: white;
            border-radius: 60px;
            padding: 0.8rem 1.5rem;
            margin: 0.5rem 0;
            cursor: grab;
            display: inline-block;
            border: 2px solid var(--primary-medium);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            transition: all 0.1s;
        }
        
        .draggable-item:active {
            cursor: grabbing;
            opacity: 0.8;
        }
        
        .dropped-item {
            background: #154f34;
            color: white;
            border-radius: 60px;
            padding: 0.6rem 1.2rem;
            margin: 0.3rem;
            display: inline-block;
            font-size: 0.9rem;
            border: 2px solid white;
        }

        /* ===== TOOL TABLE ===== */
        .tool-matrix {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border-radius: 2rem;
            overflow: hidden;
            box-shadow: 0 15px 30px rgba(0,20,0,0.1);
            margin: 2rem 0;
        }

        .tool-matrix th {
            background: var(--primary-medium);
            color: white;
            padding: 1.2rem;
            font-size: 1.2rem;
        }

        .tool-matrix td {
            padding: 1.2rem;
            border-bottom: 1px solid #c5e0c5;
            vertical-align: top;
        }

        .tool-matrix tr:last-child td {
            border-bottom: none;
        }

        /* ===== RISK MATRIX ===== */
        .risk-table {
            width: 100%;
            border-collapse: collapse;
        }

        .risk-table th {
            background: #154f34;
            color: white;
            padding: 1rem;
        }

        .risk-table td {
            border: 2px solid #b5d6b5;
            padding: 1rem;
            text-align: center;
            font-weight: 600;
        }

        .risk-low { background: #c8e6c8; }
        .risk-medium { background: #fff3b0; }
        .risk-high { background: #ffb5b5; }
        .risk-extreme { background: #ff8080; color: white; }

        /* ===== GLOSSARY STYLES ===== */
        .glossary-term {
            display: inline-block;
            background: #e3f1e3;
            border-bottom: 2px dotted var(--primary-medium);
            cursor: help;
            position: relative;
            font-weight: 500;
            padding: 0 4px;
        }

        .glossary-definition {
            display: none;
            position: absolute;
            background: var(--primary-dark);
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 1rem;
            width: 250px;
            left: 50%;
            transform: translateX(-50%);
            bottom: 100%;
            margin-bottom: 10px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            z-index: 1000;
            font-size: 0.9rem;
            font-weight: normal;
            border: 3px solid var(--accent-gold);
        }

        .glossary-term:hover .glossary-definition {
            display: block;
        }

        .glossary-definition::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -8px;
            border-width: 8px;
            border-style: solid;
            border-color: var(--primary-dark) transparent transparent transparent;
        }

        /* ===== PHOTO GALLERY STYLES ===== */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .gallery-item {
            background: var(--bg-light);
            border-radius: 1.5rem;
            overflow: hidden;
            box-shadow: 0 10px 20px rgba(0,20,0,0.1);
            transition: transform 0.3s;
            border: 2px solid var(--border-light);
        }

        .gallery-item:hover {
            transform: scale(1.02);
        }

        .gallery-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-bottom: 4px solid var(--accent-gold);
            background: #d9ead9; /* fallback while loading */
        }

        .gallery-caption {
            padding: 1.2rem;
        }

        .gallery-caption h4 {
            margin: 0 0 0.5rem 0;
            color: var(--primary-dark);
            font-size: 1.3rem;
        }

        .gallery-caption p {
            margin: 0;
            font-size: 0.95rem;
            color: #2a4a2a;
        }

        .photo-credit {
            font-size: 0.8rem;
            color: #666;
            margin-top: 0.5rem;
            font-style: italic;
        }

        /* ===== SCENARIO STYLES ===== */
        .scenario-box {
            background: #fff2db;
            border-radius: 2rem;
            padding: 2.5rem;
            margin: 2rem 0;
            border-left: 12px solid var(--accent-gold);
            box-shadow: var(--card-shadow);
        }

        .scenario-question {
            background: white;
            border-radius: 1.5rem;
            padding: 1.5rem;
            margin: 1.5rem 0;
            border: 2px solid var(--primary-light);
        }

        .scenario-options {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin: 1.5rem 0;
        }

        .scenario-option {
            background: white;
            border: 2px solid var(--border-light);
            border-radius: 60px;
            padding: 1rem 2rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .scenario-option:hover {
            background: var(--accent-soft);
            border-color: var(--accent-gold);
        }

        .scenario-option.selected {
            background: var(--primary-medium);
            color: white;
            border-color: var(--accent-gold);
        }

        .scenario-feedback {
            display: none;
            background: white;
            border-radius: 1.5rem;
            padding: 1.5rem;
            margin-top: 1.5rem;
            border: 4px solid;
        }

        .feedback-good {
            border-color: #2f7d4f;
        }

        .feedback-risky {
            border-color: var(--accent-gold);
        }

        .feedback-poor {
            border-color: #a14f4f;
        }

        /* ===== FOOTER ===== */
        .footer-expanded {
            background: #0f3829;
            color: var(--footer-text);
            padding: 2rem;
            margin-top: 2rem;
            border-top: 8px solid var(--accent-gold);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 3rem;
        }
        
        .footer-expanded h4, .footer-expanded h5 {
            color: var(--footer-heading);
            font-weight: 700;
            margin-bottom: 1.2rem; 
        }
        
        .footer-expanded a {
            color: var(--footer-heading);
            text-decoration: none;
            border-bottom: 1px dotted var(--footer-heading);
        }
        
        .footer-expanded a:hover {
            color: white;
            border-bottom: 1px solid white;
        }

        @media (max-width: 1200px) {
            .footer-grid { grid-template-columns: repeat(2, 1fr); }
            .tab-bar { padding: 0 1rem; }
            .tab { padding: 1rem; }
            .hero-banner h1 { font-size: 3rem; }
            .game-container { grid-template-columns: 1fr; }
        }

        /* ===== PRINT STYLES ===== */
        @media print {
            .tab-bar, .btn, .hero-banner, .quiz-container, .game-container, 
            .gallery-grid, .glossary-term, .scenario-box { 
                display: none !important; 
            }
            .tab-content { 
                display: block !important; 
                page-break-after: always;
                padding: 1rem;
            }
            body { 
                background: white; 
                padding: 0;
                font-size: 11pt;
            }
            .checklist-super {
                border: 2px solid black;
                box-shadow: none;
                page-break-inside: avoid;
            }
            .checklist-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .footer-expanded {
                display: none;
            }
        }
    </style>
</head>
